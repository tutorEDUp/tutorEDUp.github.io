<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Poster Generator Pro | 海報生成與設計系統</title>
    <!-- 引入 Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 FontAwesome 圖示 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gray: {
                            850: '#1f2937',
                            900: '#111827',
                            950: '#030712',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* 自訂滾動條 */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #1f2937; }
        ::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #6b7280; }
        .tab-active { border-bottom: 2px solid #3b82f6; color: #3b82f6; }
        .tab-inactive { border-bottom: 2px solid transparent; color: #9ca3af; }
        
        /* 畫布與圖層樣式 */
        .poster-container {
            width: 100%;
            aspect-ratio: 1 / 1;
            max-width: 600px;
            max-height: 600px;
            position: relative;
            overflow: hidden;
            background-color: #111827;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        
        .text-layer {
            position: absolute;
            cursor: move;
            padding: 4px 8px;
            border: 2px dashed transparent;
            user-select: none;
            white-space: pre-wrap;
            min-width: 50px;
            min-height: 30px;
            line-height: 1.2;
        }
        
        .text-layer.active {
            border-color: #3b82f6;
            background-color: rgba(59, 130, 246, 0.1);
        }

        .text-layer[contenteditable="true"] {
            cursor: text;
            outline: none;
            border-color: #10b981;
            background-color: rgba(16, 185, 129, 0.1);
        }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans h-screen overflow-hidden flex">

    <!-- 左側控制面板 -->
    <aside class="w-96 bg-gray-900 border-r border-gray-800 flex flex-col h-full z-20 shadow-xl overflow-y-auto shrink-0">
        <!-- 頂部標題與語系切換 -->
        <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-gray-900 sticky top-0 z-20">
            <h1 class="text-lg font-bold flex items-center gap-2 text-blue-400">
                <i class="fa-solid fa-layer-group"></i>
                <span data-i18n="appTitle">AI Poster Pro</span>
            </h1>
            <button id="langToggle" class="text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-full border border-gray-700 transition-colors">
                EN / 中文
            </button>
        </div>

        <div class="p-5 flex-1 space-y-6">
            <!-- 模式切換 -->
            <div>
                <div class="flex border-b border-gray-700">
                    <button id="tabImage" class="flex-1 pb-2 text-sm font-medium tab-active transition-colors flex items-center justify-center gap-2" onclick="setMode('image')">
                        <i class="fa-solid fa-image"></i> <span data-i18n="imageMode">1. 生成底圖</span>
                    </button>
                    <button id="tabText" class="flex-1 pb-2 text-sm font-medium tab-inactive transition-colors flex items-center justify-center gap-2 hover:text-gray-300" onclick="setMode('text')">
                        <i class="fa-solid fa-align-left"></i> <span data-i18n="textMode">2. 生成文案</span>
                    </button>
                </div>
            </div>

            <!-- API 設定 (文字模式需要) -->
            <div id="apiSettingsSection" class="space-y-2 hidden">
                <label class="text-xs text-gray-400 font-semibold uppercase tracking-wider flex justify-between">
                    <span data-i18n="apiSettings">OpenAI API Key (生成文字所需)</span>
                </label>
                <input type="password" id="apiKey" data-i18n-placeholder="enterApiKey" placeholder="輸入 API Key (如 sk-...)" class="w-full bg-gray-850 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500 transition-colors">
            </div>

            <!-- 提示詞輸入 -->
            <div class="space-y-2">
                <label class="text-xs text-gray-400 font-semibold uppercase tracking-wider flex justify-between">
                    <span data-i18n="promptLabel">提示詞 (Prompt)</span>
                    <span id="charCount" class="text-gray-500">0 chars</span>
                </label>
                <textarea id="promptInput" rows="5" data-i18n-placeholder="promptPlaceholder" placeholder="請描述您想要生成的海報底圖畫面..." class="w-full bg-gray-850 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500 resize-none transition-colors"></textarea>
            </div>

            <!-- 參考圖片上傳 -->
            <div class="space-y-2" id="refImageSection">
                <label class="text-xs text-gray-400 font-semibold uppercase tracking-wider flex items-center gap-1">
                    <span data-i18n="refImageLabel">上傳參考圖片 (墊圖)</span>
                    <i class="fa-solid fa-circle-info text-gray-500 text-[10px]" title="作為背景底圖或供 AI 參考"></i>
                </label>
                <div class="flex items-center gap-3">
                    <label class="flex-1 flex flex-col items-center justify-center border-2 border-dashed border-gray-700 bg-gray-850 rounded-lg p-4 cursor-pointer hover:bg-gray-800 hover:border-blue-500 transition-all">
                        <i class="fa-solid fa-cloud-arrow-up text-gray-400 mb-1"></i>
                        <span class="text-xs text-gray-400" data-i18n="uploadText">點擊上傳圖片</span>
                        <input type="file" id="imageUpload" accept="image/*" class="hidden">
                    </label>
                    <div id="imagePreviewContainer" class="hidden w-20 h-20 rounded-lg border border-gray-700 overflow-hidden relative shrink-0">
                        <img id="imagePreview" src="" alt="Preview" class="w-full h-full object-cover">
                        <button id="removeImageBtn" class="absolute top-1 right-1 bg-red-500/80 text-white rounded-full w-5 h-5 flex items-center justify-center text-[10px] hover:bg-red-600">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 生成按鈕 -->
            <button id="generateBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 rounded-lg flex items-center justify-center gap-2 transition-all shadow-lg shadow-blue-900/50">
                <i class="fa-solid fa-wand-magic-sparkles"></i>
                <span data-i18n="generateBtn">生成真實 AI 底圖</span>
            </button>
            
            <p id="freeApiNote" class="text-[10px] text-gray-500 text-center">
                * 圖片生成使用真實免費 AI 引擎，無須 API Key。
            </p>

            <!-- 文字生成結果區 (僅在文字模式顯示) -->
            <div id="textResultSection" class="hidden mt-4 pt-4 border-t border-gray-800">
                <label class="text-xs text-green-400 font-semibold uppercase tracking-wider mb-2 block">AI 生成文案結果</label>
                <div id="textOutput" class="w-full bg-gray-850 border border-gray-700 rounded-lg p-3 text-sm text-gray-300 min-h-[80px] mb-3 whitespace-pre-wrap"></div>
                <button id="addTextToPosterBtn" class="w-full bg-green-600 hover:bg-green-700 text-white font-medium py-2 rounded-lg flex items-center justify-center gap-2 transition-all hidden">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    加入海報編輯
                </button>
            </div>
        </div>
        
        <!-- 計費與 Token 面板 -->
        <div class="p-5 bg-gray-850 border-t border-gray-800 mt-auto">
            <h3 class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-3" data-i18n="costEstimate">預估花費 (即時計算)</h3>
            
            <div class="space-y-3">
                <div class="flex justify-between items-center text-sm">
                    <span class="text-gray-400 flex items-center gap-1.5"><i class="fa-solid fa-coins text-yellow-500"></i> Tokens:</span>
                    <span id="tokenCount" class="font-mono font-medium text-gray-200">0</span>
                </div>
                
                <div class="flex justify-between items-center text-sm">
                    <span class="text-gray-400">Est. USD:</span>
                    <span id="usdCost" class="font-mono font-medium text-gray-200">$0.0000</span>
                </div>

                <div class="flex justify-between items-center text-base bg-gray-900 p-2 rounded-md border border-gray-700">
                    <span class="text-green-400 font-bold">Est. HKD:</span>
                    <span id="hkdCost" class="font-mono font-bold text-green-400">HK$ 0.000</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- 右側主要內容區 (海報編輯器) -->
    <main class="flex-1 relative bg-gray-950 flex flex-col min-w-0" id="mainArea">
        <!-- 頂部工具列 -->
        <div class="h-14 border-b border-gray-800 flex justify-between items-center px-6 bg-gray-900/80 backdrop-blur-sm z-10">
            <h2 class="text-sm font-medium text-gray-300 flex items-center gap-2">
                <i class="fa-solid fa-pen-ruler"></i> <span data-i18n="outputArea">海報排版編輯器</span>
            </h2>
            
            <div class="flex items-center gap-3">
                <button id="addManualTextBtn" class="text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-lg border border-gray-700 transition-colors flex items-center gap-1">
                    <i class="fa-solid fa-plus"></i> 新增自訂文字
                </button>
                <button id="exportBtn" class="text-xs bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-lg font-medium transition-colors flex items-center gap-1 shadow-lg shadow-blue-900/50">
                    <i class="fa-solid fa-download"></i> 合成並下載海報
                </button>
            </div>
        </div>

        <!-- 圖層屬性控制列 (選擇文字時顯示) -->
        <div id="layerControls" class="absolute top-16 left-1/2 -translate-x-1/2 bg-gray-800 border border-gray-700 rounded-full px-4 py-2 flex items-center gap-4 z-20 shadow-2xl transition-all opacity-0 pointer-events-none transform -translate-y-4">
            <div class="flex items-center gap-2">
                <label class="text-xs text-gray-400">顏色</label>
                <input type="color" id="textColorPicker" class="w-6 h-6 rounded cursor-pointer bg-transparent border-0 p-0" value="#ffffff">
            </div>
            <div class="w-px h-4 bg-gray-700"></div>
            <div class="flex items-center gap-2">
                <label class="text-xs text-gray-400">大小</label>
                <input type="range" id="textSizeSlider" min="12" max="120" value="48" class="w-24 accent-blue-500">
                <span id="textSizeDisplay" class="text-xs text-gray-300 w-6">48</span>
            </div>
            <div class="w-px h-4 bg-gray-700"></div>
            <button id="deleteLayerBtn" class="text-red-400 hover:text-red-300 p-1" title="刪除選取圖層">
                <i class="fa-solid fa-trash-can"></i>
            </button>
        </div>

        <!-- 內容顯示區 -->
        <div class="flex-1 overflow-auto p-8 flex items-center justify-center relative bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-gray-900 via-gray-950 to-black" id="editorWorkspace">
            
            <!-- 載入中動畫 -->
            <div id="loadingState" class="absolute inset-0 z-30 hidden flex-col items-center justify-center bg-gray-950/80 backdrop-blur-sm">
                <i class="fa-solid fa-circle-notch fa-spin text-5xl text-blue-500 mb-4"></i>
                <p class="text-blue-400 font-medium text-lg tracking-wider animate-pulse" id="loadingText">AI 正在繪製真實圖片...</p>
            </div>

            <!-- 海報畫布容器 -->
            <div id="posterContainer" class="poster-container rounded-sm">
                <!-- 預設提示文字 -->
                <div id="emptyCanvasHint" class="absolute inset-0 flex flex-col items-center justify-center text-gray-600 pointer-events-none">
                    <i class="fa-solid fa-image text-5xl mb-3 opacity-30"></i>
                    <p class="text-sm">在左側生成 AI 圖片作為海報底圖</p>
                </div>

                <!-- 背景圖片 -->
                <img id="posterBackground" src="" class="absolute inset-0 w-full h-full object-cover hidden" crossorigin="anonymous">
                
                <!-- 這裡會動態插入文字圖層 (.text-layer) -->
            </div>

        </div>
        
        <!-- 畫布操作提示 -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-gray-900/80 backdrop-blur border border-gray-800 text-gray-400 text-xs px-4 py-2 rounded-full pointer-events-none flex items-center gap-3">
            <span><i class="fa-solid fa-hand-pointer"></i> 拖曳移動</span>
            <span><i class="fa-solid fa-i-cursor"></i> 雙擊編輯文字</span>
            <span><i class="fa-solid fa-mouse-pointer"></i> 點擊選取修改樣式</span>
        </div>
    </main>

    <script>
        // === 狀態與常數 ===
        let currentMode = 'image'; // 'image' | 'text'
        let currentLang = 'zh';
        let uploadedImageBase64 = null;
        
        // 圖層狀態
        let activeLayer = null;
        let isDragging = false;
        let startX, startY, initialLeft, initialTop;
        
        // 匯率與計費標準
        const RATES = {
            usdToHkd: 7.8,
            textInputPer1k: 0.005,
            textOutputPer1k: 0.015,
            imagePerGen: 0.04
        };

        const i18n = {
            zh: {
                appTitle: "AI Poster Pro",
                imageMode: "1. 生成底圖",
                textMode: "2. 生成文案",
                apiSettings: "OpenAI API Key (生成文字所需)",
                enterApiKey: "輸入 API Key (如 sk-...)",
                promptLabel: "提示詞 (Prompt)",
                promptPlaceholder: "請描述您想要生成的海報底圖畫面...",
                promptPlaceholderText: "請輸入您的海報主題，AI 將為您撰寫行銷文案...",
                refImageLabel: "上傳參考圖片 (墊圖)",
                uploadText: "點擊上傳圖片",
                generateBtn: "生成真實 AI 底圖",
                generateBtnText: "生成 AI 海報文案",
                costEstimate: "預估花費 (即時計算)",
                outputArea: "海報排版編輯器"
            },
            en: {
                appTitle: "AI Poster Pro",
                imageMode: "1. Background",
                textMode: "2. Copywriting",
                apiSettings: "OpenAI API Key (For Text)",
                enterApiKey: "Enter API Key (sk-...)",
                promptLabel: "Prompt",
                promptPlaceholder: "Describe the poster background image...",
                promptPlaceholderText: "Enter your topic, AI will write poster copy...",
                refImageLabel: "Reference Image",
                uploadText: "Click to upload",
                generateBtn: "Generate AI Background",
                generateBtnText: "Generate AI Copy",
                costEstimate: "Estimated Cost",
                outputArea: "Poster Editor"
            }
        };

        // === DOM 元素 ===
        const elements = {
            promptInput: document.getElementById('promptInput'),
            charCount: document.getElementById('charCount'),
            tokenCount: document.getElementById('tokenCount'),
            usdCost: document.getElementById('usdCost'),
            hkdCost: document.getElementById('hkdCost'),
            imageUpload: document.getElementById('imageUpload'),
            imagePreviewContainer: document.getElementById('imagePreviewContainer'),
            imagePreview: document.getElementById('imagePreview'),
            removeImageBtn: document.getElementById('removeImageBtn'),
            generateBtn: document.getElementById('generateBtn'),
            langToggle: document.getElementById('langToggle'),
            tabText: document.getElementById('tabText'),
            tabImage: document.getElementById('tabImage'),
            apiSettingsSection: document.getElementById('apiSettingsSection'),
            freeApiNote: document.getElementById('freeApiNote'),
            apiKey: document.getElementById('apiKey'),
            
            // 編輯器
            posterContainer: document.getElementById('posterContainer'),
            posterBackground: document.getElementById('posterBackground'),
            emptyCanvasHint: document.getElementById('emptyCanvasHint'),
            loadingState: document.getElementById('loadingState'),
            loadingText: document.getElementById('loadingText'),
            
            // 文字結果
            textResultSection: document.getElementById('textResultSection'),
            textOutput: document.getElementById('textOutput'),
            addTextToPosterBtn: document.getElementById('addTextToPosterBtn'),
            addManualTextBtn: document.getElementById('addManualTextBtn'),
            
            // 圖層控制
            layerControls: document.getElementById('layerControls'),
            textColorPicker: document.getElementById('textColorPicker'),
            textSizeSlider: document.getElementById('textSizeSlider'),
            textSizeDisplay: document.getElementById('textSizeDisplay'),
            deleteLayerBtn: document.getElementById('deleteLayerBtn'),
            exportBtn: document.getElementById('exportBtn'),
            mainArea: document.getElementById('mainArea')
        };

        // === 初始化與切換邏輯 ===
        function setMode(mode) {
            currentMode = mode;
            if (mode === 'image') {
                elements.tabImage.className = "flex-1 pb-2 text-sm font-medium tab-active transition-colors flex items-center justify-center gap-2";
                elements.tabText.className = "flex-1 pb-2 text-sm font-medium tab-inactive transition-colors flex items-center justify-center gap-2 hover:text-gray-300";
                
                elements.apiSettingsSection.classList.add('hidden');
                elements.freeApiNote.classList.remove('hidden');
                elements.promptInput.placeholder = i18n[currentLang].promptPlaceholder;
                elements.generateBtn.innerHTML = `<i class="fa-solid fa-wand-magic-sparkles"></i> <span>${i18n[currentLang].generateBtn}</span>`;
                elements.textResultSection.classList.add('hidden');
            } else {
                elements.tabText.className = "flex-1 pb-2 text-sm font-medium tab-active transition-colors flex items-center justify-center gap-2";
                elements.tabImage.className = "flex-1 pb-2 text-sm font-medium tab-inactive transition-colors flex items-center justify-center gap-2 hover:text-gray-300";
                
                elements.apiSettingsSection.classList.remove('hidden');
                elements.freeApiNote.classList.add('hidden');
                elements.promptInput.placeholder = i18n[currentLang].promptPlaceholderText;
                elements.generateBtn.innerHTML = `<i class="fa-solid fa-pen-nib"></i> <span>${i18n[currentLang].generateBtnText}</span>`;
            }
            calculateCost();
        }

        elements.langToggle.addEventListener('click', () => {
            currentLang = currentLang === 'zh' ? 'en' : 'zh';
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18n[currentLang][key]) el.textContent = i18n[currentLang][key];
            });
            document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
                const key = el.getAttribute('data-i18n-placeholder');
                if (i18n[currentLang][key]) el.placeholder = i18n[currentLang][key];
            });
            setMode(currentMode); // 重新應用佔位符號
        });

        // === 圖片上傳 ===
        elements.imageUpload.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    uploadedImageBase64 = e.target.result;
                    elements.imagePreview.src = uploadedImageBase64;
                    elements.imagePreviewContainer.classList.remove('hidden');
                    
                    // 如果有上傳圖片，直接放入畫布作為底圖
                    elements.posterBackground.src = uploadedImageBase64;
                    elements.posterBackground.classList.remove('hidden');
                    elements.emptyCanvasHint.classList.add('hidden');
                    
                    calculateCost();
                }
                reader.readAsDataURL(file);
            }
        });

        elements.removeImageBtn.addEventListener('click', function() {
            uploadedImageBase64 = null;
            elements.imageUpload.value = '';
            elements.imagePreviewContainer.classList.add('hidden');
            elements.imagePreview.src = '';
            // 如果沒有其他 AI 圖片，則隱藏背景
            if (!elements.posterBackground.src.includes('pollinations')) {
                elements.posterBackground.classList.add('hidden');
                elements.emptyCanvasHint.classList.remove('hidden');
            }
            calculateCost();
        });

        // === 即時計算費用 ===
        function calculateCost() {
            const text = elements.promptInput.value;
            elements.charCount.textContent = `${text.length} chars`;

            let estimatedTokens = Math.ceil(text.length * 1.5);
            let usd = 0;

            if (currentMode === 'text') {
                if (uploadedImageBase64) estimatedTokens += 250;
                let inputCost = (estimatedTokens / 1000) * RATES.textInputPer1k;
                let outputCost = text.length > 0 ? (300 / 1000) * RATES.textOutputPer1k : 0; 
                usd = inputCost + outputCost;
            } else if (currentMode === 'image') {
                usd = text.length > 0 ? RATES.imagePerGen : 0;
            }

            elements.tokenCount.textContent = estimatedTokens.toLocaleString();
            elements.usdCost.textContent = `$${usd.toFixed(4)}`;
            elements.hkdCost.textContent = `HK$ ${(usd * RATES.usdToHkd).toFixed(3)}`;
        }
        elements.promptInput.addEventListener('input', calculateCost);

        // === API 生成邏輯 (核心) ===
        elements.generateBtn.addEventListener('click', async () => {
            const prompt = elements.promptInput.value.trim();
            if (!prompt) {
                alert(currentLang === 'zh' ? '請先輸入提示詞！' : 'Please enter a prompt!');
                return;
            }

            elements.generateBtn.disabled = true;

            if (currentMode === 'image') {
                // 【真實 AI 圖片生成】 使用 Pollinations AI (免費, 支援即時生成)
                elements.loadingState.classList.remove('hidden');
                elements.loadingState.classList.add('flex');
                elements.loadingText.textContent = currentLang === 'zh' ? "AI 正在繪製真實海報底圖..." : "Generating real AI image...";
                
                // 加上隨機種子確保每次生成都不同
                const seed = Math.floor(Math.random() * 1000000);
                const imageUrl = `https://image.pollinations.ai/prompt/${encodeURIComponent(prompt)}?width=1024&height=1024&nologo=true&seed=${seed}`;
                
                const img = new Image();
                img.crossOrigin = "anonymous";
                img.onload = () => {
                    elements.posterBackground.src = imageUrl;
                    elements.posterBackground.classList.remove('hidden');
                    elements.emptyCanvasHint.classList.add('hidden');
                    
                    elements.loadingState.classList.add('hidden');
                    elements.loadingState.classList.remove('flex');
                    elements.generateBtn.disabled = false;
                };
                img.onerror = () => {
                    alert('圖片生成失敗，請稍後再試。');
                    elements.loadingState.classList.add('hidden');
                    elements.generateBtn.disabled = false;
                }
                img.src = imageUrl;

            } else {
                // 【真實 AI 文字生成】 使用 OpenAI API
                const apiKey = elements.apiKey.value.trim();
                if (!apiKey) {
                    alert(currentLang === 'zh' ? '請輸入 OpenAI API Key 以生成文案。' : 'Please enter OpenAI API Key.');
                    elements.generateBtn.disabled = false;
                    return;
                }

                elements.generateBtn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> 生成中...`;
                elements.textResultSection.classList.remove('hidden');
                elements.textOutput.textContent = "AI 思考中...";
                elements.addTextToPosterBtn.classList.add('hidden');

                try {
                    const response = await fetch('https://api.openai.com/v1/chat/completions', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${apiKey}`
                        },
                        body: JSON.stringify({
                            model: 'gpt-3.5-turbo',
                            messages: [
                                { role: 'system', content: '你是一位專業的海報文案撰寫專家。請根據使用者的主題，提供簡短、有吸引力、適合放在海報上的標題與副標題。' },
                                { role: 'user', content: prompt }
                            ],
                            max_tokens: 150
                        })
                    });

                    const data = await response.json();
                    
                    if (data.error) throw new Error(data.error.message);
                    
                    const generatedText = data.choices[0].message.content;
                    elements.textOutput.textContent = generatedText;
                    elements.addTextToPosterBtn.classList.remove('hidden');

                } catch (error) {
                    elements.textOutput.textContent = `生成錯誤: ${error.message}`;
                } finally {
                    elements.generateBtn.disabled = false;
                    elements.generateBtn.innerHTML = `<i class="fa-solid fa-pen-nib"></i> <span>${i18n[currentLang].generateBtnText}</span>`;
                }
            }
        });

        // 將生成的文案加入海報
        elements.addTextToPosterBtn.addEventListener('click', () => {
            const text = elements.textOutput.textContent;
            if (text && !text.startsWith('AI 思考中') && !text.startsWith('生成錯誤')) {
                addTextLayer(text);
            }
        });

        elements.addManualTextBtn.addEventListener('click', () => {
            addTextLayer("雙擊此處編輯文字");
        });

        // === 海報排版與拖曳邏輯 ===
        function addTextLayer(textContent) {
            const layer = document.createElement('div');
            layer.className = 'text-layer text-white font-bold drop-shadow-2xl';
            layer.style.left = '50px';
            layer.style.top = '50px';
            layer.style.fontSize = '48px';
            layer.style.fontFamily = 'sans-serif';
            layer.style.color = '#ffffff';
            layer.style.textShadow = '2px 2px 4px rgba(0,0,0,0.8), 0px 0px 10px rgba(0,0,0,0.5)'; // 強烈陰影確保可見性
            layer.innerText = textContent;

            // 雙擊進入編輯模式
            layer.addEventListener('dblclick', (e) => {
                layer.contentEditable = true;
                layer.focus();
                e.stopPropagation();
            });

            // 失去焦點退出編輯
            layer.addEventListener('blur', () => {
                layer.contentEditable = false;
            });

            // 選取圖層與拖曳設定
            layer.addEventListener('mousedown', (e) => {
                if (layer.contentEditable === 'true') return; // 編輯中不拖曳
                
                isDragging = true;
                activeLayer = layer;
                startX = e.clientX;
                startY = e.clientY;
                initialLeft = parseInt(layer.style.left) || 0;
                initialTop = parseInt(layer.style.top) || 0;
                
                selectLayer(layer);
                e.stopPropagation();
            });

            elements.posterContainer.appendChild(layer);
            selectLayer(layer);
        }

        // 全域拖曳事件
        document.addEventListener('mousemove', (e) => {
            if (!isDragging || !activeLayer) return;
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            activeLayer.style.left = `${initialLeft + dx}px`;
            activeLayer.style.top = `${initialTop + dy}px`;
        });

        document.addEventListener('mouseup', () => {
            isDragging = false;
        });

        // 點擊空白處取消選取
        elements.posterContainer.addEventListener('mousedown', (e) => {
            if (e.target === elements.posterContainer || e.target === elements.posterBackground || e.target === elements.emptyCanvasHint) {
                deselectLayer();
            }
        });

        // 選取圖層並更新控制列
        function selectLayer(layer) {
            document.querySelectorAll('.text-layer').forEach(el => el.classList.remove('active'));
            layer.classList.add('active');
            activeLayer = layer;

            // 顯示控制列並同步數值
            elements.layerControls.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
            
            // 將 rgb 轉 hex 給 color picker
            const rgb = window.getComputedStyle(layer).color;
            elements.textColorPicker.value = rgbToHex(rgb);
            
            const size = parseInt(window.getComputedStyle(layer).fontSize);
            elements.textSizeSlider.value = size;
            elements.textSizeDisplay.textContent = size;
        }

        function deselectLayer() {
            document.querySelectorAll('.text-layer').forEach(el => el.classList.remove('active'));
            activeLayer = null;
            elements.layerControls.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
        }

        // 圖層屬性修改事件
        elements.textColorPicker.addEventListener('input', (e) => {
            if (activeLayer) activeLayer.style.color = e.target.value;
        });

        elements.textSizeSlider.addEventListener('input', (e) => {
            if (activeLayer) {
                activeLayer.style.fontSize = `${e.target.value}px`;
                elements.textSizeDisplay.textContent = e.target.value;
            }
        });

        elements.deleteLayerBtn.addEventListener('click', () => {
            if (activeLayer) {
                activeLayer.remove();
                deselectLayer();
            }
        });

        // 輔助工具：RGB 轉 HEX
        function rgbToHex(rgb) {
            const match = rgb.match(/^rgb\((\d+),\s*(\d+),\s*(\d+)\)$/);
            if (!match) return '#ffffff';
            function hex(x) { return ("0" + parseInt(x).toString(16)).slice(-2); }
            return "#" + hex(match[1]) + hex(match[2]) + hex(match[3]);
        }

        // === 合成與匯出海報 ===
        elements.exportBtn.addEventListener('click', () => {
            if (elements.posterBackground.classList.contains('hidden')) {
                alert(currentLang === 'zh' ? '請先生成或上傳底圖！' : 'Please generate a background first!');
                return;
            }

            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            const img = elements.posterBackground;

            // 設定畫布尺寸為圖片實際渲染的尺寸(正方形容器)
            const rect = elements.posterContainer.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = rect.height;

            // 繪製底圖 (維持 object-cover 的比例)
            // 這裡簡化處理，因為容器與圖片皆強制為 1:1 比例
            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

            // 繪製文字圖層
            document.querySelectorAll('.text-layer').forEach(layer => {
                const style = window.getComputedStyle(layer);
                const left = parseFloat(style.left);
                const top = parseFloat(style.top);
                const fontSize = parseFloat(style.fontSize);
                const text = layer.innerText;
                const lines = text.split('\n'); // 處理多行文字

                ctx.font = `${style.fontWeight} ${fontSize}px ${style.fontFamily}`;
                ctx.fillStyle = style.color;
                ctx.textBaseline = 'top';
                
                // 陰影設定
                ctx.shadowColor = 'rgba(0,0,0,0.8)';
                ctx.shadowBlur = 10;
                ctx.shadowOffsetX = 2;
                ctx.shadowOffsetY = 2;

                // 繪製每一行
                let currentTop = top + 4; // 扣除 padding 的微調
                lines.forEach(line => {
                    ctx.fillText(line, left + 8, currentTop); // 加上 left padding
                    currentTop += fontSize * 1.2; // 簡單的行高
                });
            });

            // 下載
            try {
                const link = document.createElement('a');
                link.download = `ai_poster_${Date.now()}.png`;
                link.href = canvas.toDataURL('image/png');
                link.click();
            } catch (err) {
                alert('跨域限制導致無法直接下載，請使用截圖或右鍵另存圖片。');
                console.error(err);
            }
        });

    </script>
</body>
</html>
